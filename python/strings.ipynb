    "# Strings"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "85fd92cf-95ce-459a-ba79-7c287e1314a3",
   "metadata": {},
   "source": [
    "## Get string length"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "08533a6c-de48-4455-aa30-24f0f1a8df51",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Length of the string is: 12\n"
     ]
    }
   ],
   "source": [
    "string = \"Hello world!\"\n",
    "print(\"Length of the string is: {}\".format(len(string)))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7f60fdc3-e9bf-47a5-bf80-4226d47ca032",
   "metadata": {},
   "source": [
    "## Substring"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "0892324a-9db7-49ab-863a-bfee80056c52",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hello world!\n",
      "Substring[6:11]: world\n"
     ]
    }
   ],
   "source": [
    "string = \"Hello world!\"\n",
    "substring = string[:]\n",
    "print(substring)\n",
    "substring = string[6:11]\n",
    "print(\"Substring[6:11]:\", substring)"
   ]
  },
